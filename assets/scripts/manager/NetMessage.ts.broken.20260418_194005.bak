    private handleGame_Notify属�?arr: any[], idxArr: number): void {
        const mainTest = this.mainTest;
        if (!mainTest || !mainTest.scene战斗) return;

        const id = arr[idxArr++];
        const entity = mainTest.scene战斗.entities.get(id);

        if (!entity) {
            // console.warn('已离开战斗场景，无法更新属�?', id);
            return;
        }

        const obj属性数�?= arr[idxArr++] as object;
        const barCache = this.getEntityBarCache(id, entity);
        this.刷新单位状态条尺寸(entity);

        for (const key in obj属性数�? {
            const 属�?= parseInt(key) as 属性类�?
            const 数�?= obj属性数值[key];
            entity.obj属性数值[属性] = 数�?

            switch (属�? {
                case 属性类�?生命:
                    if (entity.node血�? {
                        if (entity.hpMax > 0) {
                            barCache.lastHpProgress = this.setBarFillIfChanged(
                                barCache.hpFillNode,
                                数�?/ entity.hpMax,
                                barCache.lastHpProgress,
                            );
                        } else {
                            entity.node血�?active = false; // 资源没有血�?                        }
                    }
                    break;

                case 属性类�?能量:
                    if (entity.node能量�? {
                        const energyProgress = entity.能量Max > 0 ? 数�?/ entity.能量Max : 0;
                        barCache.lastEnergyProgress = this.setBarFillIfChanged(
                            barCache.energyFillNode,
                            energyProgress,
                            barCache.lastEnergyProgress,
                        );
                    }
                    break;
            }
        }
        this.刷新3D名字颜色(id, entity);
    }
